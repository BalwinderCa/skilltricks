# rsync exclude list for deploy-staging.sh (rsync filter patterns).
# Leading "/" anchors to the project root. Excluded paths are also protected
# from --delete, so the server's copies of .env, vendor/, storage/ are never
# touched by a deploy.

# --- VCS & CI ---------------------------------------------------------------
/.git/
/.github/
.gitignore
.gitattributes

# --- Local editor/agent state ----------------------------------------------
/.claude/
/.cursor/

# --- Secrets / keys / env (managed on the server, never overwrite) ----------
.env
.env.*
*.pem
/id_skilltricks_new*
/id_rsa_skilltricks*
/id_ed25519*
/PUBLIC_KEY.txt
/deploy.config

# --- Dependencies (rebuilt on the server via composer install) --------------
/vendor/
/node_modules/

# --- Server-managed runtime state -------------------------------------------
# Exclude ALL of storage/ — the server owns its uploads, logs, sessions, cache
# and debugbar dumps. deploy-staging.sh recreates the framework dir skeleton on
# the server for first-time deploys. Excluded paths are also protected from
# rsync --delete, so the server's storage is never touched.
/storage/
/bootstrap/cache/*.php
/public/storage

# --- Build tooling & frontend sources (only the built public/ assets ship) --
/package.json
/package-lock.json
/webpack.mix.js
/.editorconfig

# --- Tests & static analysis (not needed in production) ---------------------
/tests/
/phpunit.xml
/.phpunit.result.cache
/phpstan.neon
/phpstan-baseline.neon
/pint.json

# --- Docs & local notes -----------------------------------------------------
/docs/
/README.md
/readme-to-update.txt
*.md
/change-list.text
/run_migrations.py

# --- Server-managed dirs we should not clobber ------------------------------
/cgi-bin/

# --- Deploy artifacts & local junk ------------------------------------------
/deploy-staging.sh
/.deployignore
/deploy.config.example
*.sql
*.sql.gz
*.zip
*.log
upload_log.txt
.DS_Store
