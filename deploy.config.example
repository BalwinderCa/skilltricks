# Copy this file to "deploy.config" (which is gitignored) and fill in real
# values. deploy-staging.sh sources it automatically. Any variable can also be
# overridden ad hoc via the environment, e.g.:
#   REMOTE_PATH=public_html/staging2 ./deploy-staging.sh

# --- SSH connection ---------------------------------------------------------
SSH_HOST="217.21.90.136"
SSH_USER="u684149649"
SSH_PORT="65002"

# Path to the private SSH key (relative to the repo root or absolute).
SSH_KEY="./id_skilltricks_new"

# --- Remote layout ----------------------------------------------------------
# Target directory, relative to the SSH user's home (~).
REMOTE_PATH="public_html/staging"

# --- Remote tooling ---------------------------------------------------------
# Override if the host exposes PHP/Composer under different names, e.g.:
#   REMOTE_PHP="php8.2"
#   REMOTE_COMPOSER="php8.2 /home/u684149649/composer.phar"
REMOTE_PHP="php"
REMOTE_COMPOSER="composer"
