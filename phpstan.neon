includes:
    - vendor/nunomaduro/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 4
    paths:
        - app
    # Brownfield: existing issues are captured in phpstan-baseline.neon so CI
    # only fails on NEW problems. Regenerate with:
    #   vendor/bin/phpstan analyse --generate-baseline
    treatPhpDocTypesAsCertain: false
