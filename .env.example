APP_NAME="SkillTrick"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION=1.0.0

# Demo mode: must be Off in production. Demo reset routes only work when APP_ENV=local AND DEMO_MODE=On
DEMO_MODE=Off
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=usd
DEFAULT_CURRENCY_SYMBOL=$
DEFAULT_PAGINATION=10

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=skilltricks
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# AI providers
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_SECRET_KEY=
OPENAI_MODEL=gpt-4-turbo
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Payment gateways (fill in per environment; never commit real values)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
RAZORPAY_KEY=
RAZORPAY_SECRET=

# Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=

# Error tracking (see docs/WEEK3_INFRA_SETUP.md)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Production checklist:
# - APP_ENV=production, APP_DEBUG=false, DEMO_MODE=Off
# - CACHE_DRIVER=redis, QUEUE_CONNECTION=redis, SESSION_DRIVER=redis
# - REDIS_HOST / REDIS_PASSWORD / REDIS_PORT configured for your environment
# - php artisan config:cache && php artisan route:cache && php artisan view:cache
# - Run queue workers via Supervisor (see config/supervisor/skilltricks-worker.conf.example)
# - Cron: * * * * * php /path/to/artisan schedule:run >> /dev/null 2>&1
# - Health probe: php artisan health:check
# - Never commit .env or SSH private keys (e.g. id_skilltricks_new)
